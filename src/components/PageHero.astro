---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, subtitle, align = 'left' } = Astro.props;
---

<section class:list={['page-hero', `align-${align}`]}>
  <div class="container">
    {eyebrow && <span class="eyebrow">{eyebrow}</span>}
    <h1>{title}</h1>
    {subtitle && <p class="page-sub">{subtitle}</p>}
  </div>
</section>

<style>
  .page-hero {
    padding: 56px 0 36px;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(124, 58, 237, 0.08), transparent);
  }
  @media (min-width: 768px) {
    .page-hero {
      padding: 80px 0 48px;
    }
  }
  .page-hero h1 {
    font-size: clamp(30px, 4.5vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 14px;
    max-width: 820px;
  }
  .align-center h1,
  .align-center .page-sub {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }
  .align-center {
    text-align: center;
  }
  .page-sub {
    font-size: 17px;
    color: var(--color-text-muted);
    max-width: 720px;
  }
</style>
