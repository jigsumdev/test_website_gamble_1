---
interface FaqItem {
  q: string;
  a: string;
}
interface Props {
  items?: FaqItem[];
}

const defaultItems: FaqItem[] = [
  {
    q: 'What does FairLedger actually do?',
    a: 'FairLedger is an independent transparency project for the crypto casino industry. We index every public blockchain deposit to known operator wallets, audit the math behind Original (in-house) games, verify every bonus code we publish and write reviews based on actual deposits and withdrawals.',
  },
  {
    q: 'How are you funded?',
    a: 'Most external links to operators are affiliate links. When you sign up via FairLedger, the casino pays us a percentage of their gross gaming revenue from your account. We pass between 50% and 100% of that revenue back to you as wager-share rewards. We have no equity in any operator and no operator pays for ranking or coverage.',
  },
  {
    q: 'How is your deposit volume data accurate?',
    a: 'Operator hot wallets and treasury wallets are public. We tag every wallet attributable to a casino, then sum the inbound transactions on Bitcoin, Ethereum, Tron, Solana, Lightning and other chains. Methodology and a per-casino wallet ledger are published on the transparency page.',
  },
  {
    q: 'Are these casinos safe?',
    a: 'Every casino we cover holds at least a Curacao or Anjouan gaming license, has been operating for more than 12 months and processes withdrawals within our published median time. We do not list operators with unresolved player-fund disputes.',
  },
  {
    q: 'How do FairLedger bonus codes work?',
    a: 'Use code FAIRLEDGER (or LEDGER on some sites) at signup. The code attributes your account to FairLedger, unlocks our negotiated rakeback or boosted welcome offer, and credits any wager-share rewards to your FairLedger account each Sunday at 23:59 UTC.',
  },
  {
    q: 'Is gambling legal where I live?',
    a: 'Probably not in every jurisdiction we cover. Crypto casinos typically restrict players from the United States, the United Kingdom, France, Australia and a handful of other regulated markets. Check our jurisdiction restrictions page and your own local law before depositing.',
  },
];

const { items = defaultItems } = Astro.props;
---

<div class="faq-list">
  {
    items.map((it) => (
      <details class="faq-item">
        <summary>
          <span>{it.q}</span>
          <span class="faq-icon" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14">
              <path d="M3 5.5 7 9.5 11 5.5" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </summary>
        <div class="faq-body">
          <p>{it.a}</p>
        </div>
      </details>
    ))
  }
</div>

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: defaultItems.map((it) => ({
      '@type': 'Question',
      name: it.q,
      acceptedAnswer: { '@type': 'Answer', text: it.a },
    })),
  })}
/>

<style>
  .faq-list {
    display: grid;
    gap: 8px;
    max-width: 820px;
    margin: 0 auto;
  }
  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.15s ease;
  }
  .faq-item[open] {
    border-color: var(--color-primary);
  }
  .faq-item summary {
    list-style: none;
    cursor: pointer;
    padding: 18px 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-weight: 600;
    color: #fff;
    font-size: 15.5px;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary:hover {
    background: rgba(124, 58, 237, 0.06);
  }
  .faq-icon {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(124, 58, 237, 0.12);
    color: var(--color-primary-soft);
    transition: transform 0.18s ease;
    flex-shrink: 0;
  }
  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }
  .faq-body {
    padding: 0 20px 20px;
    color: var(--color-text-muted);
    font-size: 14.5px;
    line-height: 1.6;
  }
</style>
