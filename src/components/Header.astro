---
import Logo from './Logo.astro';
import {
  headerPrimary,
  headerToolsDropdown,
  headerCompanyDropdown,
  routeSlugs,
  type RouteKey,
} from '~/data/site';

interface Props {
  routeKey: RouteKey;
}

const { routeKey } = Astro.props;
const currentPath = routeSlugs[routeKey];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <div class="header-left">
      <Logo />
      <nav class="primary-nav" aria-label="Primary">
        <ul>
          {
            headerPrimary.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={['nav-link', { active: isActive(item.href) }]}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                >
                  {item.label}
                  {item.badge && <span class="nav-badge">{item.badge}</span>}
                </a>
              </li>
            ))
          }
          <li class="dropdown">
            <button class="nav-link dropdown-trigger" aria-expanded="false" aria-haspopup="true">
              Tools
              <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
              </svg>
            </button>
            <div class="dropdown-menu" role="menu">
              {
                headerToolsDropdown.items.map((item) => (
                  <a class="dropdown-item" href={item.href} role="menuitem">
                    <span class="dropdown-item-title">{item.label}</span>
                    {item.description && <span class="dropdown-item-desc">{item.description}</span>}
                  </a>
                ))
              }
            </div>
          </li>
          <li class="dropdown">
            <button class="nav-link dropdown-trigger" aria-expanded="false" aria-haspopup="true">
              Company
              <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                <path d="M3 4.5 6 7.5 9 4.5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" />
              </svg>
            </button>
            <div class="dropdown-menu narrow" role="menu">
              {
                headerCompanyDropdown.items.map((item) => (
                  <a class="dropdown-item" href={item.href} role="menuitem">
                    <span class="dropdown-item-title">{item.label}</span>
                  </a>
                ))
              }
            </div>
          </li>
        </ul>
      </nav>
    </div>

    <div class="header-right">
      <a href="/livecodes/" class="btn btn-ghost btn-sm hide-md">
        <span class="dot dot-pulse" aria-hidden="true"></span>
        Live codes
      </a>
      <a href="/contact/" class="btn btn-secondary btn-sm">Sign in</a>
      <a href="/casinos/" class="btn btn-primary btn-sm">Get started</a>
      <button class="mobile-trigger" data-mobile-trigger aria-label="Toggle menu" aria-expanded="false">
        <svg width="22" height="22" viewBox="0 0 22 22" aria-hidden="true">
          <line x1="3" y1="6" x2="19" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="3" y1="11" x2="19" y2="11" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          <line x1="3" y1="16" x2="19" y2="16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" data-mobile-menu hidden>
    <nav aria-label="Mobile navigation">
      <ul>
        {headerPrimary.map((item) => (
          <li><a href={item.href} class:list={['mobile-link', { active: isActive(item.href) }]}>{item.label}{item.badge && <span class="nav-badge">{item.badge}</span>}</a></li>
        ))}
        <li class="mobile-divider">Tools</li>
        {headerToolsDropdown.items.map((item) => (
          <li><a href={item.href} class="mobile-link">{item.label}</a></li>
        ))}
        <li class="mobile-divider">Company</li>
        {headerCompanyDropdown.items.map((item) => (
          <li><a href={item.href} class="mobile-link">{item.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(11, 15, 30, 0.78);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    height: var(--header-h);
  }
  .header-left {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
    min-width: 0;
  }
  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .primary-nav {
    display: none;
  }
  @media (min-width: 1024px) {
    .primary-nav {
      display: block;
    }
  }
  .primary-nav ul {
    display: flex;
    gap: 4px;
    align-items: center;
  }
  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 12px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-soft);
    transition: all 0.15s ease;
    cursor: pointer;
    white-space: nowrap;
  }
  .nav-link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: #fff;
  }
  .nav-link.active {
    color: #fff;
    background: rgba(124, 58, 237, 0.15);
  }
  .nav-badge {
    display: inline-block;
    padding: 1px 7px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    background: linear-gradient(135deg, #ec4899, #7c3aed);
    color: #fff;
    text-transform: uppercase;
  }
  .dropdown {
    position: relative;
  }
  .dropdown-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 280px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 8px;
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: all 0.18s ease;
    z-index: 60;
  }
  .dropdown-menu.narrow {
    min-width: 200px;
  }
  .dropdown:hover .dropdown-menu,
  .dropdown:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown-item {
    display: block;
    padding: 10px 12px;
    border-radius: 8px;
    transition: background 0.12s ease;
  }
  .dropdown-item:hover {
    background: rgba(124, 58, 237, 0.12);
  }
  .dropdown-item-title {
    display: block;
    font-weight: 600;
    color: #fff;
    font-size: 14px;
  }
  .dropdown-item-desc {
    display: block;
    font-size: 12.5px;
    color: var(--color-text-muted);
    margin-top: 2px;
  }
  .hide-md {
    display: none;
  }
  @media (min-width: 768px) {
    .hide-md {
      display: inline-flex;
    }
  }
  .mobile-trigger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    color: #fff;
    border: 1px solid var(--color-border);
  }
  .mobile-trigger:hover {
    background: rgba(255, 255, 255, 0.04);
  }
  @media (min-width: 1024px) {
    .mobile-trigger {
      display: none;
    }
  }

  .mobile-menu {
    border-top: 1px solid var(--color-border);
    padding: 14px 20px 22px;
    background: var(--color-bg-2);
  }
  .mobile-menu[hidden] {
    display: none;
  }
  .mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .mobile-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-radius: 8px;
    font-weight: 500;
    color: var(--color-text-soft);
  }
  .mobile-link:hover,
  .mobile-link.active {
    background: rgba(124, 58, 237, 0.12);
    color: #fff;
  }
  .mobile-divider {
    margin-top: 10px;
    padding: 8px 12px 4px;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    font-weight: 700;
  }
</style>

<script>
  const trigger = document.querySelector<HTMLButtonElement>('[data-mobile-trigger]');
  const menu = document.querySelector<HTMLElement>('[data-mobile-menu]');
  if (trigger && menu) {
    trigger.addEventListener('click', () => {
      const open = !menu.hasAttribute('hidden');
      if (open) {
        menu.setAttribute('hidden', '');
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        menu.removeAttribute('hidden');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  }

  // Hover-intent dropdowns also work on click for keyboard users
  document.querySelectorAll<HTMLButtonElement>('.dropdown-trigger').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const parent = btn.closest('.dropdown');
      if (!parent) return;
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
      e.preventDefault();
    });
  });
</script>
