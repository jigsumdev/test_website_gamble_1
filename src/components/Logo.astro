---
interface Props {
  size?: number;
  withWordmark?: boolean;
}
const { size = 28, withWordmark = true } = Astro.props;
---

<a href="/" class="brand" aria-label="FairLedger home">
  <span class="mark" style={`width:${size}px;height:${size}px;`}>
    <svg viewBox="0 0 32 32" width={size} height={size} aria-hidden="true">
      <defs>
        <linearGradient id="lg" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
          <stop offset="0%" stop-color="#A78BFA" />
          <stop offset="55%" stop-color="#7C3AED" />
          <stop offset="100%" stop-color="#14B8A6" />
        </linearGradient>
      </defs>
      <rect x="2" y="2" width="28" height="28" rx="8" fill="url(#lg)" />
      <path
        d="M9 22 V10 H22 M9 16 H19"
        stroke="#0B0F1E"
        stroke-width="2.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        fill="none"
      />
    </svg>
  </span>
  {withWordmark && <span class="wordmark">FairLedger</span>}
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
    font-size: 17px;
  }
  .mark {
    display: inline-flex;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  .wordmark {
    background: linear-gradient(135deg, #ffffff 0%, #c4b5fd 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
</style>
