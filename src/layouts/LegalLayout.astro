---
import BaseLayout from './BaseLayout.astro';
import { LEGAL_LAST_UPDATED, pageMeta, type RouteKey } from '~/data/site';

interface Props {
  routeKey: RouteKey;
}
const { routeKey } = Astro.props;
const meta = pageMeta[routeKey];
const updated = new Date(LEGAL_LAST_UPDATED).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const headingTitle = meta.title.split(' | ')[0]?.split(' - ')[0] ?? meta.title;
---

<BaseLayout routeKey={routeKey}>
  <section class="legal-hero">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <span>{headingTitle}</span>
      </nav>
      <h1>{headingTitle}</h1>
      <p class="last-updated">
        Last updated: <time datetime={LEGAL_LAST_UPDATED}>{updated}</time>
      </p>
    </div>
  </section>

  <section class="legal-body">
    <div class="container">
      <article class="prose">
        <slot />
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-hero {
    padding: 56px 0 32px;
    border-bottom: 1px solid var(--color-border);
    background: linear-gradient(180deg, rgba(124, 58, 237, 0.08), transparent);
  }
  .breadcrumb {
    display: flex;
    gap: 8px;
    font-size: 13px;
    color: var(--color-text-muted);
    margin-bottom: 14px;
  }
  .breadcrumb a {
    color: var(--color-primary-soft);
  }
  .breadcrumb a:hover {
    color: #c4b5fd;
  }
  .legal-hero h1 {
    font-size: clamp(28px, 4vw, 40px);
    margin-bottom: 8px;
  }
  .last-updated {
    color: var(--color-text-muted);
    font-size: 14px;
  }
  .legal-body {
    padding: 56px 0 96px;
  }
  .prose {
    max-width: 760px;
  }
</style>
