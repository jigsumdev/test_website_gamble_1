---
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import { casinos } from '~/data/casinos';
---

<BaseLayout routeKey="reviews">
  <PageHero
    eyebrow="Independent reviews"
    title="Honest reviews from people who actually deposit"
    subtitle="Every review starts with a real-money deposit, ends with a real-money withdrawal and is updated every 90 days. No copy-paste from operator press kits."
  />

  <section class="section">
    <div class="container">
      <div class="review-list">
        {
          casinos.map((c) => (
            <article class="review card card-hover">
              <div class="review-head">
                <div class="logo-tile size-64" style={`background-color:${c.brandColor};`} aria-hidden="true">
                  {c.logoInitials}
                </div>
                <div class="review-meta">
                  <h2>{c.name}</h2>
                  <div class="review-stars">
                    <span class="stars">{'★'.repeat(Math.round(c.rating))}{'☆'.repeat(5 - Math.round(c.rating))}</span>
                    <span class="rating-num">{c.rating.toFixed(1)} / 5</span>
                    <span class="meta-dot">·</span>
                    <span class="meta-text">Est. {c.established}</span>
                    <span class="meta-dot">·</span>
                    <span class="meta-text">{c.license}</span>
                  </div>
                  <p class="review-desc">{c.description}</p>
                </div>
              </div>

              <div class="review-pros-cons">
                <div>
                  <h3 class="pc-title text-success">What we like</h3>
                  <ul>{c.pros.map((p) => <li>+ {p}</li>)}</ul>
                </div>
                <div>
                  <h3 class="pc-title text-danger">What could be better</h3>
                  <ul>{c.cons.map((p) => <li>- {p}</li>)}</ul>
                </div>
              </div>

              <div class="review-foot">
                <div class="review-stats">
                  <div class="rs">
                    <span class="rs-key">Payout</span>
                    <span class="rs-val">{c.payout}</span>
                  </div>
                  <div class="rs">
                    <span class="rs-key">Rakeback</span>
                    <span class="rs-val">{c.rakebackPct}%</span>
                  </div>
                  <div class="rs">
                    <span class="rs-key">Welcome</span>
                    <span class="rs-val">{c.signupBonus}</span>
                  </div>
                </div>
                <div class="review-cta">
                  <code class="code-pill">{c.promoCode}</code>
                  <a class="btn btn-primary btn-sm" href={c.url} rel="nofollow sponsored noopener" target="_blank">Visit {c.name}</a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .review-list {
    display: grid;
    gap: 22px;
  }
  .review {
    padding: 26px;
  }
  .review-head {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 18px;
    margin-bottom: 22px;
  }
  .review h2 {
    font-size: 22px;
    margin-bottom: 6px;
  }
  .review-stars {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 10px;
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .stars {
    color: #fbbf24;
    font-size: 14px;
  }
  .rating-num {
    color: #fff;
    font-weight: 600;
  }
  .meta-dot {
    color: var(--color-text-dim);
  }
  .review-desc {
    color: var(--color-text-soft);
    font-size: 14.5px;
  }
  .review-pros-cons {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    margin-bottom: 22px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.025);
    border-radius: var(--radius);
    border: 1px solid var(--color-border-soft);
  }
  @media (min-width: 720px) {
    .review-pros-cons {
      grid-template-columns: 1fr 1fr;
    }
  }
  .pc-title {
    font-size: 12.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 8px;
    font-weight: 700;
  }
  .review-pros-cons li {
    color: var(--color-text-soft);
    font-size: 13.5px;
    line-height: 1.6;
  }
  .review-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 18px;
    padding-top: 18px;
    border-top: 1px solid var(--color-border-soft);
  }
  .review-stats {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
  }
  .rs {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .rs-key {
    font-size: 11px;
    color: var(--color-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 700;
  }
  .rs-val {
    color: #fff;
    font-weight: 600;
    font-size: 14px;
  }
  .review-cta {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .code-pill {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    background: rgba(124, 58, 237, 0.18);
    color: var(--color-primary-soft);
    padding: 5px 10px;
    border-radius: 999px;
    border: 1px solid rgba(124, 58, 237, 0.32);
  }
</style>
