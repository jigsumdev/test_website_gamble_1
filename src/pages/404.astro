---
import BaseLayout from '~/layouts/BaseLayout.astro';
---

<BaseLayout
  routeKey="home"
  title="Page not found - FairLedger"
  description="The page you were looking for does not exist."
>
  <section class="not-found">
    <div class="container">
      <span class="eyebrow">Error 404</span>
      <h1><span class="grad">Lost in the chain.</span></h1>
      <p>
        The page you were looking for does not exist, has been moved or the
        operator just delisted itself. Let&apos;s get you back to a known wallet.
      </p>
      <div class="nf-cta">
        <a class="btn btn-primary btn-lg" href="/">Back to home</a>
        <a class="btn btn-secondary btn-lg" href="/casinos/">Browse casinos</a>
        <a class="btn btn-ghost btn-lg" href="/sitemap/">Open sitemap</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 0;
  }
  .not-found h1 {
    font-size: clamp(40px, 8vw, 80px);
    margin: 12px 0 18px;
    line-height: 1;
  }
  .grad {
    background: linear-gradient(135deg, #c4b5fd 0%, #7c3aed 50%, #14b8a6 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .not-found p {
    font-size: 17px;
    color: var(--color-text-muted);
    max-width: 540px;
    margin: 0 auto 28px;
  }
  .nf-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }
</style>
